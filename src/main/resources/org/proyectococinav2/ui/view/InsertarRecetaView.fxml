<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>


<AnchorPane xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.proyectococinav2.ui.controller.InsertarRecetaViewController">
   <children>
      <VBox alignment="CENTER" spacing="10.0" AnchorPane.bottomAnchor="16.0" AnchorPane.leftAnchor="180.0" AnchorPane.rightAnchor="180.0" AnchorPane.topAnchor="17.0">
      
          <Label alignment="CENTER" text="Insertar Receta">
              <font>
                  <Font size="24.0" />
              </font>
          </Label>
          <TextField fx:id="recipeNameField" maxWidth="Infinity" promptText="Nombre de la receta" />
      
          <Label text="Instrucciones:">
              <VBox.margin>
                  <Insets top="10.0" />
              </VBox.margin>
          </Label>
          <ScrollPane fitToHeight="true" fitToWidth="true" prefHeight="120.0">
              <content>
                  <TextArea fx:id="instructionArea" prefHeight="100.0" prefRowCount="5" prefWidth="308.0" promptText="Instrucciones: " wrapText="true" />
              </content>
          </ScrollPane>
          <Label text="Ingredientes:" />
          <ScrollPane fx:id="ingredientsScrollPane" fitToWidth="true" prefHeight="180.0">
              <content>
                  <VBox fx:id="ingredientBox" spacing="10" />
              </content>
          </ScrollPane>
          <HBox alignment="CENTER" spacing="50.0">
              <Button onAction="#onAddIngredient" prefHeight="25.0" prefWidth="125.0" text="Agregar Ingrediente" />
              <Button onAction="#onCancel" text="Cancelar" />
              <Button onAction="#onSaveRecipe" text="Guardar Receta" />
              <VBox.margin>
                  <Insets bottom="20.0" top="20.0" />
              </VBox.margin>
            <opaqueInsets>
               <Insets />
            </opaqueInsets>
          </HBox>
      </VBox>
   </children>
</AnchorPane>
