<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>


<AnchorPane xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.proyectococinav2.ui.controller.IngredienteFormViewController">
   <children>
      <VBox alignment="CENTER" spacing="10.0" AnchorPane.bottomAnchor="16.0" AnchorPane.leftAnchor="180.0" AnchorPane.rightAnchor="180.0" AnchorPane.topAnchor="17.0">
      
          <Label alignment="CENTER" text="Formulario Ingrediente">
              <font>
                  <Font size="24.0" />
              </font>
          </Label>
          <TextField fx:id="ingredientNameField" maxWidth="Infinity" promptText="Nombre del ingrediente" />
      
          <Label text="Proveedor:">
              <VBox.margin>
                  <Insets top="10.0" />
              </VBox.margin>
          </Label>
          <ComboBox fx:id="proveedorComboBox" promptText="Selecciona un proveedor" maxWidth="Infinity" />
          
          <HBox alignment="CENTER" spacing="50.0">
              <Button onAction="#onCancel" text="Cancelar" />
              <Button onAction="#onSaveIngredient" text="Guardar Ingrediente" />
              <VBox.margin>
                  <Insets bottom="20.0" top="20.0" />
              </VBox.margin>
            <opaqueInsets>
               <Insets />
            </opaqueInsets>
          </HBox>
      </VBox>
   </children>
</AnchorPane>
