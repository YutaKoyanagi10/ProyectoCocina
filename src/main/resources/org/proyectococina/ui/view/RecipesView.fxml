<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<VBox alignment="TOP_CENTER" spacing="20" xmlns="http://javafx.com/javafx/17.0.12" 
      xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="org.proyectococina.ui.controller.RecipesViewController">
    
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <Label text="Lista de Recetas">
        <font>
            <Font name="System Bold" size="28.0" />
        </font>
    </Label>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Buscar:" />
        <TextField fx:id="searchField" promptText="Buscar receta por nombre o instrucción..." HBox.hgrow="ALWAYS" />
    </HBox>

    <TableView fx:id="recipesTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="idColumn" text="ID" />
            <TableColumn fx:id="nameColumn" text="Nombre" />
            <TableColumn fx:id="instructionColumn" text="Instrucción" />
            <TableColumn fx:id="insertedAtColumn" text="Fecha Alta" />
            <TableColumn fx:id="updatedAtColumn" text="Última Modificación" />
            <TableColumn fx:id="actionsColumn" text="Acciones" />
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>
</VBox>
