<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<VBox alignment="TOP_CENTER" spacing="20" xmlns="http://javafx.com/javafx/17.0.12" 
      xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="org.proyectococina.ui.controller.MenuSemanalViewController">
    
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <Label text="Lista de Menús Semanales">
        <font>
            <Font name="System Bold" size="28.0" />
        </font>
    </Label>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Buscar:" />
        <TextField fx:id="searchField" promptText="Buscar por nombre de menú o fecha..." HBox.hgrow="ALWAYS" />
    </HBox>

    <TableView fx:id="menuTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="idColumn" text="ID" prefWidth="50" />
            <TableColumn fx:id="nombreColumn" text="Nombre del Menú" prefWidth="200" />
            <TableColumn fx:id="fechaInicioColumn" text="Fecha Inicio (Lunes)" prefWidth="150" />
            <TableColumn fx:id="fechaAltaColumn" text="Fecha Alta" prefWidth="150" />
            <TableColumn fx:id="fechaModColumn" text="Última Modificación" prefWidth="150" />
            <TableColumn fx:id="accionesColumn" text="Acciones" prefWidth="200" />
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>
</VBox>