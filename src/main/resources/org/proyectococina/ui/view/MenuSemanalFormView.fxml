<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<VBox alignment="TOP_CENTER" spacing="20" xmlns="http://javafx.com/javafx/17.0.12" 
      xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="org.proyectococina.ui.controller.MenuSemanalFormViewController">
    
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <Label fx:id="titleLabel" text="Nuevo Menú Semanal">
        <font>
            <Font name="System Bold" size="28.0" />
        </font>
    </Label>

    <HBox spacing="10" alignment="CENTER">
        <Label text="Nombre del Menú:" />
        <TextField fx:id="nameField" promptText="Ej: Menú Semanal 1" HBox.hgrow="ALWAYS" />
        <Label text="Fecha Lunes:" />
        <DatePicker fx:id="startDatePicker" />
    </HBox>

    <Separator />

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
        <GridPane fx:id="weeklyGrid" hgap="10" vgap="10" alignment="CENTER">
            <padding>
                <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
            </padding>
            </GridPane>
    </ScrollPane>

    <HBox spacing="20" alignment="CENTER">
        <Button fx:id="btnGuardar" text="Guardar" onAction="#onGuardar" prefWidth="200" />
        <Button fx:id="btnCancelar" text="Cancelar" onAction="#onCancelar" prefWidth="200" />
    </HBox>
</VBox>