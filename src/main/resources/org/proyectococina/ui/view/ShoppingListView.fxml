<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<VBox alignment="TOP_CENTER" spacing="20" xmlns="http://javafx.com/javafx/17.0.12" 
      xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="org.proyectococina.ui.controller.ShoppingListViewController">
    
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <Label text="Lista de Compras">
        <font>
            <Font name="System Bold" size="28.0" />
        </font>
    </Label>

    <HBox spacing="15" alignment="CENTER">
        <Label text="Seleccionar Menú:" />
        <ComboBox fx:id="menuSelector" promptText="Elija un menú..." prefWidth="300" />
    </HBox>

    <Separator />

    <Label text="Ajustar Comensales por Plato">
        <font>
            <Font name="System Bold" size="16.0" />
        </font>
    </Label>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
        <VBox fx:id="itemsContainer" spacing="10">
            <padding>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
            </padding>
            </VBox>
    </ScrollPane>

    <HBox spacing="20" alignment="CENTER">
        <Button fx:id="btnCalculate" text="Generar Lista de Compras" 
                onAction="#onExportShoppingList" prefHeight="40.0" prefWidth="250.0" />
    </HBox>
</VBox>